# =====================================================================
# Environment variable template for the prod stack (deploy/docker-compose.yml → env_file: ../.env.prod)
#
# Usage:
#   cp .env.example .env.prod
#   edit .env.prod with real secrets — .env.prod is listed in .gitignore
# =====================================================================

# Database (PostgreSQL service in deploy/docker-compose.yml)
POSTGRES_USER=prod_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=prod_database

# Quarkus datasource (pg-database = service name on the same Docker network)
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://pg-database:5432/prod_database
QUARKUS_DATASOURCE_USERNAME=prod_user
QUARKUS_DATASOURCE_PASSWORD=changeme

# Quarkus
QUARKUS_HIBERNATE_ORM_DATABASE_GENERATION=update
QUARKUS_PROFILE=prod
QUARKUS_LOG_CONSOLE_JSON_PRETTY_PRINT=false

# Optional OIDC (activate profile "secured" — see docs/security/oidc-secured-profile.md)
# QUARKUS_PROFILE=prod,secured
# QUARKUS_OIDC_AUTH_SERVER_URL=https://keycloak.example/realms/your-realm
# QUARKUS_OIDC_CLIENT_ID=quarkus-app
# QUARKUS_OIDC_CLIENT_SECRET=
