{
  "openapi" : "3.1.0",
  "components" : {
    "schemas" : {
      "Category" : {
        "required" : [ "id", "name" ],
        "description" : "Product category",
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "integer",
            "format" : "int64",
            "examples" : [ 1 ]
          },
          "name" : {
            "type" : "string",
            "examples" : [ "Electronics" ]
          }
        }
      },
      "FieldError" : {
        "type" : "object",
        "description" : "Single bean-validation violation.",
        "properties" : {
          "field" : {
            "type" : "string",
            "description" : "Dotted path to the offending field.",
            "examples" : [ "price" ]
          },
          "message" : {
            "type" : "string",
            "description" : "Violation message.",
            "examples" : [ "must be greater than or equal to 0" ]
          }
        }
      },
      "Instant" : {
        "type" : "string",
        "format" : "date-time",
        "examples" : [ "2022-03-10T16:15:50Z" ]
      },
      "MeResponse" : {
        "description" : "Resolved identity from the OIDC access token",
        "type" : "object",
        "properties" : {
          "subject" : {
            "type" : "string"
          },
          "roles" : {
            "type" : "array",
            "uniqueItems" : true,
            "items" : {
              "type" : "string"
            }
          }
        }
      },
      "PagedResponse" : {
        "description" : "Paged response: page data and metadata",
        "type" : "object",
        "properties" : {
          "data" : {
            "type" : "array",
            "items" : { },
            "description" : "Items of the current page"
          },
          "totalPages" : {
            "type" : "integer",
            "format" : "int32",
            "description" : "Total number of pages"
          },
          "totalElements" : {
            "type" : "integer",
            "format" : "int64",
            "description" : "Total number of elements"
          },
          "currentPage" : {
            "type" : "integer",
            "format" : "int32",
            "description" : "Current page number (0-based)"
          }
        }
      },
      "PingResponse" : {
        "type" : "object",
        "properties" : {
          "status" : {
            "type" : "string"
          }
        }
      },
      "Problem" : {
        "description" : "RFC 7807 application/problem+json error body.",
        "examples" : [ {
          "type" : "about:blank",
          "title" : "Not Found",
          "status" : 404,
          "detail" : "Product 42 not found",
          "instance" : "/products/42",
          "requestId" : "8f5a2b20-2c3a-4df0-9c6c-52b21f9a4b63",
          "timestamp" : "2026-04-18T12:34:56.789Z"
        } ],
        "type" : "object",
        "properties" : {
          "type" : {
            "type" : "string",
            "format" : "uri",
            "description" : "URI reference that identifies the problem type. Defaults to 'about:blank'.",
            "examples" : [ "about:blank" ]
          },
          "title" : {
            "type" : "string",
            "description" : "Short, human-readable summary of the problem type (does not change per occurrence).",
            "examples" : [ "Not Found" ]
          },
          "status" : {
            "type" : "integer",
            "format" : "int32",
            "maximum" : 599,
            "minimum" : 100,
            "description" : "HTTP status code generated by the origin server for this occurrence.",
            "examples" : [ 404 ]
          },
          "detail" : {
            "type" : "string",
            "description" : "Human-readable explanation specific to this occurrence of the problem.",
            "examples" : [ "Product 42 not found" ]
          },
          "instance" : {
            "type" : "string",
            "format" : "uri",
            "description" : "URI reference that identifies the specific occurrence (request path).",
            "examples" : [ "/products/42" ]
          },
          "requestId" : {
            "type" : "string",
            "description" : "Correlation id (mirrors X-Request-Id response header and MDC).",
            "examples" : [ "8f5a2b20-2c3a-4df0-9c6c-52b21f9a4b63" ]
          },
          "timestamp" : {
            "description" : "Server timestamp (UTC, ISO-8601) when the error was produced.",
            "type" : "string",
            "examples" : [ "2026-04-18T12:34:56.789Z" ],
            "$ref" : "#/components/schemas/Instant"
          },
          "errors" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/FieldError"
            },
            "description" : "Per-field validation errors (only populated for 400 from bean validation)."
          }
        }
      },
      "Product" : {
        "required" : [ "id", "name", "price" ],
        "description" : "Product in the catalog",
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "integer",
            "format" : "int64",
            "examples" : [ 1 ]
          },
          "name" : {
            "type" : "string",
            "examples" : [ "Coffee" ]
          },
          "price" : {
            "type" : "number",
            "format" : "double",
            "examples" : [ 12.50 ]
          },
          "categoryId" : {
            "type" : [ "integer", "null" ],
            "format" : "int64",
            "description" : "Category id if set"
          }
        }
      },
      "ProductRequest" : {
        "required" : [ "name", "price" ],
        "description" : "Fields for creating and updating a product",
        "type" : "object",
        "properties" : {
          "name" : {
            "type" : "string",
            "description" : "Name",
            "examples" : [ "Laptop" ],
            "pattern" : "\\S"
          },
          "price" : {
            "type" : "number",
            "format" : "double",
            "description" : "Price ≥ 0",
            "examples" : [ 999.99 ],
            "minimum" : 0
          },
          "categoryId" : {
            "type" : [ "integer", "null" ],
            "format" : "int64",
            "description" : "Optional category link"
          }
        }
      }
    },
    "securitySchemes" : {
      "oidc-jwt" : {
        "description" : "Authentication",
        "type" : "http",
        "scheme" : "bearer",
        "bearerFormat" : "JWT"
      }
    }
  },
  "tags" : [ {
    "name" : "Categories",
    "description" : "Product categories (read)"
  }, {
    "name" : "Products",
    "description" : "CRUD and recommendations for products"
  }, {
    "name" : "Config",
    "description" : "Non-secret configuration and diagnostics (no secrets)."
  }, {
    "name" : "Greeting",
    "description" : "Plain-text hello and goodbye endpoints."
  }, {
    "name" : "Admin",
    "description" : "Authorization example (role-protected endpoint)."
  } ],
  "paths" : {
    "/api/admin/ping" : {
      "get" : {
        "summary" : "Admin ping",
        "description" : "Requires role 'admin'.",
        "operationId" : "adminPing",
        "tags" : [ "Admin" ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/PingResponse"
                }
              }
            }
          },
          "401" : {
            "description" : "Unauthenticated",
            "content" : {
              "application/problem+json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Problem"
                }
              }
            }
          },
          "403" : {
            "description" : "Forbidden (missing role)",
            "content" : {
              "application/problem+json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Problem"
                }
              }
            }
          }
        },
        "security" : [ {
          "oidc-jwt" : [ ]
        } ]
      }
    },
    "/bye" : {
      "get" : {
        "summary" : "Goodbye message",
        "description" : "Returns a fixed goodbye string (demo endpoint).",
        "operationId" : "getBye",
        "tags" : [ "Greeting" ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "text/plain" : {
                "schema" : {
                  "type" : "string"
                }
              }
            }
          }
        }
      }
    },
    "/categories" : {
      "get" : {
        "summary" : "List categories",
        "description" : "Returns all product categories sorted by name.",
        "operationId" : "listCategories",
        "tags" : [ "Categories" ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Category"
                }
              }
            }
          }
        }
      }
    },
    "/categories/{id}" : {
      "get" : {
        "summary" : "Category by id",
        "description" : "Returns a single category by numeric id, or 404 if not found.",
        "operationId" : "getCategoryById",
        "tags" : [ "Categories" ],
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "integer",
            "format" : "int64"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "Found",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Category"
                }
              }
            }
          },
          "404" : {
            "description" : "Not found",
            "content" : {
              "application/problem+json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/config/greeting-message" : {
      "get" : {
        "summary" : "Configured greeting text",
        "description" : "Returns the raw `greeting.message` value as plain text.",
        "operationId" : "getGreetingMessage",
        "tags" : [ "Config" ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "text/plain" : {
                "schema" : {
                  "type" : "string"
                }
              }
            }
          }
        }
      }
    },
    "/config/public" : {
      "get" : {
        "summary" : "Public configuration slice",
        "description" : "Returns a JSON map of safe, non-secret settings (ports, app name, feature flags). Do not add secrets to this response.",
        "operationId" : "getPublicConfig",
        "tags" : [ "Config" ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "object",
                  "additionalProperties" : { }
                }
              }
            }
          }
        }
      }
    },
    "/hello" : {
      "get" : {
        "summary" : "Greeting message",
        "description" : "Returns the configured greeting string (see `greeting.message`).",
        "operationId" : "getHello",
        "tags" : [ "Greeting" ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "text/plain" : {
                "schema" : {
                  "type" : "string"
                }
              }
            }
          }
        }
      }
    },
    "/products" : {
      "get" : {
        "summary" : "Product list",
        "description" : "Paginated list with totalPages, totalElements, currentPage, and data items.",
        "operationId" : "listProducts",
        "tags" : [ "Products" ],
        "parameters" : [ {
          "name" : "page",
          "in" : "query",
          "schema" : {
            "type" : "integer",
            "format" : "int32",
            "default" : 0
          }
        }, {
          "name" : "size",
          "in" : "query",
          "schema" : {
            "type" : "integer",
            "format" : "int32",
            "default" : 20
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/PagedResponse"
                }
              }
            }
          }
        }
      },
      "post" : {
        "summary" : "Create product",
        "description" : "Creates a new product; returns 201 with Location and body, or validation/category errors.",
        "operationId" : "createProduct",
        "tags" : [ "Products" ],
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/ProductRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "201" : {
            "description" : "Created",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Product"
                }
              }
            }
          },
          "400" : {
            "description" : "Validation error",
            "content" : {
              "application/problem+json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Problem"
                }
              }
            }
          },
          "404" : {
            "description" : "Category not found (if categoryId provided)",
            "content" : {
              "application/problem+json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/products/{id}" : {
      "put" : {
        "summary" : "Update product",
        "description" : "Replaces fields of an existing product; 404 if product or category missing.",
        "operationId" : "updateProduct",
        "tags" : [ "Products" ],
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "integer",
            "format" : "int64"
          }
        } ],
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/ProductRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "Updated",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Product"
                }
              }
            }
          },
          "400" : {
            "description" : "Validation error",
            "content" : {
              "application/problem+json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Problem"
                }
              }
            }
          },
          "404" : {
            "description" : "Product or category not found",
            "content" : {
              "application/problem+json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      },
      "get" : {
        "summary" : "Product by id",
        "description" : "Returns one product by id, or 404 if not found.",
        "operationId" : "getProductById",
        "tags" : [ "Products" ],
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "integer",
            "format" : "int64"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "Found",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Product"
                }
              }
            }
          },
          "404" : {
            "description" : "Not found",
            "content" : {
              "application/problem+json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      },
      "delete" : {
        "summary" : "Delete product",
        "description" : "Deletes a product by id; 204 on success, 404 if not found.",
        "operationId" : "deleteProduct",
        "tags" : [ "Products" ],
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "integer",
            "format" : "int64"
          }
        } ],
        "responses" : {
          "204" : {
            "description" : "Deleted"
          },
          "404" : {
            "description" : "Not found",
            "content" : {
              "application/problem+json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    },
    "/products/{id}/recommendations" : {
      "get" : {
        "summary" : "Product recommendations",
        "description" : "Returns recommendation payload for a product; fault tolerance (delay) may apply.",
        "operationId" : "getProductRecommendations",
        "tags" : [ "Products" ],
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "integer",
            "format" : "int64"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "application/json" : {
                "schema" : { }
              }
            }
          },
          "404" : {
            "description" : "Not found",
            "content" : {
              "application/problem+json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Problem"
                }
              }
            }
          }
        }
      }
    }
  },
  "info" : {
    "title" : "Quarkus MS Gold Template API",
    "version" : "1.0.0-SNAPSHOT",
    "description" : "Reference REST API for the Gold Template: diagnostics, configuration endpoints, and the catalog bounded context (products and categories).",
    "contact" : {
      "name" : "Platform / template maintainers",
      "email" : "platform@example.com"
    }
  },
  "servers" : [ {
    "url" : "http://localhost:8080",
    "description" : "Auto generated value"
  }, {
    "url" : "http://0.0.0.0:8080",
    "description" : "Auto generated value"
  } ]
}